{
  "name": "wsc3d-han-stone-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:ai\"",
    "dev:backend": "tsx watch backend/src/server.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts --host 127.0.0.1",
    "dev:ai": "cd ai-service && python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "tsc -p frontend/tsconfig.json && vite build --config frontend/vite.config.ts",
    "scan": "tsx backend/src/scripts/scan.ts",
    "migrate:iiml-frame": "tsx backend/src/scripts/migrate-iiml-frame.ts",
    "start:backend": "node dist/backend/server.js",
    "typecheck": "tsc -p backend/tsconfig.json --noEmit && tsc -p frontend/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "ajv": "^8.20.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "cytoscape": "^3.33.3",
    "express": "^5.2.1",
    "konva": "^10.3.0",
    "lucide-react": "^0.555.0",
    "morgan": "^1.10.1",
    "polygon-clipping": "^0.15.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-konva": "^19.2.3",
    "three": "^0.181.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/cytoscape": "^3.21.9",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
